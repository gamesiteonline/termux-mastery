{
  "cleanUrls": true,
  "trailingSlash": false,
  "rewrites": [
    { "source": "/_content/(.*)", "destination": "/_content/$1" },
    { "source": "/banner.jpg", "destination": "/banner.jpg" },
    { "source": "/assets/(.*)", "destination": "/assets/$1" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
